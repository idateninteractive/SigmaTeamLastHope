import React, { useState, useEffect, useRef } from "react";
import { 
  Trash2, 
  Upload, 
  Plus, 
  Lock, 
  Image as ImageIcon, 
  Search, 
  Eye, 
  Download, 
  LogOut, 
  AlertCircle, 
  CheckCircle, 
  X,
  FileImage,
  Sparkles,
  Maximize2,
  Sun,
  Moon,
  Laptop,
  Flame,
  Grid,
  ChevronRight,
  ShieldCheck
} from "lucide-react";
import { motion, AnimatePresence } from "motion/react";

interface Wallpaper {
  id: string;
  title: string;
  url: string;
  resolution: string;
  category: string;
  uploadedAt: string;
}

const DEFAULT_WALLPAPERS: Wallpaper[] = [
  {
    id: "1",
    title: "Silent Field Red Tree",
    url: "/src/assets/images/silent_field_red_tree_1783074234299.jpg",
    resolution: "3840 x 2160",
    category: "Nature",
    uploadedAt: "2026-07-03"
  },
  {
    id: "2",
    title: "Abstract Red White Lines",
    url: "/src/assets/images/abstract_red_white_lines_1783074249955.jpg",
    resolution: "3840 x 2160",
    category: "Abstract",
    uploadedAt: "2026-07-03"
  },
  {
    id: "3",
    title: "Misty Red Reeds",
    url: "/src/assets/images/misty_red_reeds_1783074263922.jpg",
    resolution: "3840 x 2160",
    category: "Minimalist",
    uploadedAt: "2026-07-03"
  },
  {
    id: "4",
    title: "Minimal Red Sun",
    url: "/src/assets/images/minimal_red_sun_1783074277920.jpg",
    resolution: "3840 x 2160",
    category: "Minimalist",
    uploadedAt: "2026-07-03"
  }
];

export default function App() {
  // Theme state: dark / day (light)
  const [isDark, setIsDark] = useState<boolean>(() => {
    return localStorage.getItem("silent_fields_dark") === "true";
  });

  // Current tab view: public gallery vs admin portal
  const [activeTab, setActiveTab] = useState<"gallery" | "admin">("gallery");

  const [isLoggedIn, setIsLoggedIn] = useState<boolean>(() => {
    return sessionStorage.getItem("is_logged_in") === "true";
  });
  
  const [username, setUsername] = useState<string>("");
  const [password, setPassword] = useState<string>("");
  const [loginError, setLoginError] = useState<string>("");
  
  const [wallpapers, setWallpapers] = useState<Wallpaper[]>([]);
  const [searchQuery, setSearchQuery] = useState<string>("");
  const [categoryFilter, setCategoryFilter] = useState<string>("All");
  
  // Title reveal state
  const [titleVisible, setTitleVisible] = useState<boolean>(false);
  
  // Upload States
  const [dragActive, setDragActive] = useState<boolean>(false);
  const [uploadTitle, setUploadTitle] = useState<string>("");
  const [uploadCategory, setUploadCategory] = useState<string>("Minimalist");
  const [uploadFile, setUploadFile] = useState<File | null>(null);
  const [uploadPreview, setUploadPreview] = useState<string | null>(null);
  const [uploadError, setUploadError] = useState<string>("");
  const [uploadSuccess, setUploadSuccess] = useState<boolean>(false);
  const fileInputRef = useRef<HTMLInputElement>(null);

  // Preview Modal State
  const [selectedWallpaper, setSelectedWallpaper] = useState<Wallpaper | null>(null);
  // Delete Confirmation State
  const [deleteConfirmId, setDeleteConfirmId] = useState<string | null>(null);

  // Set document title
  useEffect(() => {
    document.title = "Silent Fields - Minimalist Red & White Wallpapers";
  }, []);

  // Sync theme to local storage
  useEffect(() => {
    localStorage.setItem("silent_fields_dark", String(isDark));
  }, [isDark]);

  // Load Wallpapers
  useEffect(() => {
    const stored = localStorage.getItem("wallpapers_list");
    if (stored) {
      try {
        setWallpapers(JSON.parse(stored));
      } catch (e) {
        setWallpapers(DEFAULT_WALLPAPERS);
      }
    } else {
      setWallpapers(DEFAULT_WALLPAPERS);
      localStorage.setItem("wallpapers_list", JSON.stringify(DEFAULT_WALLPAPERS));
    }
  }, []);

  // Save Wallpapers
  const saveWallpapers = (list: Wallpaper[]) => {
    setWallpapers(list);
    localStorage.setItem("wallpapers_list", JSON.stringify(list));
  };

  const handleLogin = (e: React.FormEvent) => {
    e.preventDefault();
    if (username === "SigmaTeam" && password === "SigmaTeam") {
      setIsLoggedIn(true);
      sessionStorage.setItem("is_logged_in", "true");
      setLoginError("");
      setUsername("");
      setPassword("");
    } else {
      setLoginError("Access Denied: Invalid credentials.");
    }
  };

  const handleLogout = () => {
    setIsLoggedIn(false);
    sessionStorage.removeItem("is_logged_in");
  };

  // Upload Helpers
  const handleDrag = (e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    if (e.type === "dragenter" || e.type === "dragover") {
      setDragActive(true);
    } else if (e.type === "dragleave") {
      setDragActive(false);
    }
  };

  const processFile = (file: File) => {
    if (!file.type.startsWith("image/")) {
      setUploadError("Only image files are allowed.");
      return;
    }
    setUploadFile(file);
    setUploadError("");
    
    const cleanName = file.name.split(".")[0]
      .split(/[-_]/)
      .map(word => word.charAt(0).toUpperCase() + word.slice(1))
      .join(" ");
    setUploadTitle(cleanName);

    const reader = new FileReader();
    reader.onload = (e) => {
      setUploadPreview(e.target?.result as string);
    };
    reader.readAsDataURL(file);
  };

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault();
    e.stopPropagation();
    setDragActive(false);
    
    if (e.dataTransfer.files && e.dataTransfer.files[0]) {
      processFile(e.dataTransfer.files[0]);
    }
  };

  const handleFileChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    if (e.target.files && e.target.files[0]) {
      processFile(e.target.files[0]);
    }
  };

  const handleUploadSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    if (!uploadPreview || !uploadTitle) {
      setUploadError("Please select an image and enter a title.");
      return;
    }

    const newWallpaper: Wallpaper = {
      id: Date.now().toString(),
      title: uploadTitle,
      url: uploadPreview,
      resolution: "3840 x 2160",
      category: uploadCategory,
      uploadedAt: new Date().toISOString().split("T")[0]
    };

    const updated = [newWallpaper, ...wallpapers];
    saveWallpapers(updated);
    
    setUploadFile(null);
    setUploadPreview(null);
    setUploadTitle("");
    setUploadSuccess(true);
    setTimeout(() => setUploadSuccess(false), 3000);
  };

  const handleDeleteWallpaper = (id: string) => {
    const updated = wallpapers.filter(w => w.id !== id);
    saveWallpapers(updated);
    setDeleteConfirmId(null);
  };

  const filteredWallpapers = wallpapers.filter(w => {
    const matchesSearch = w.title.toLowerCase().includes(searchQuery.toLowerCase()) || 
                          w.category.toLowerCase().includes(searchQuery.toLowerCase());
    const matchesCategory = categoryFilter === "All" || w.category === categoryFilter;
    return matchesSearch && matchesCategory;
  });

  const categories = ["All", "Nature", "Abstract", "Minimalist", "Custom"];

  // Colors mapping based on Theme
  const themeClasses = {
    bg: isDark ? "bg-black text-red-500" : "bg-white text-red-600",
    text: isDark ? "text-red-500" : "text-red-600",
    subtext: isDark ? "text-red-400/80" : "text-red-700/85",
    border: isDark ? "border-red-600/80" : "border-red-600",
    borderDashed: isDark ? "border-dashed border-red-500/50" : "border-dashed border-red-600/60",
    cardBg: isDark ? "bg-zinc-950" : "bg-white",
    cardHover: isDark ? "hover:border-red-500" : "hover:border-red-600",
    input: isDark ? "bg-neutral-900 border-red-600/80 text-red-400 placeholder-red-700/40" : "bg-white border-red-600 text-red-600 placeholder-red-600/40",
    buttonSolid: isDark ? "bg-red-600 text-black hover:bg-black hover:text-red-500 border-red-600" : "bg-red-600 text-white hover:bg-white hover:text-red-600 border-red-600",
    buttonOutline: isDark ? "border-red-600 text-red-500 hover:bg-neutral-900" : "border-red-600 text-red-600 hover:bg-red-50",
    tabActive: isDark ? "bg-red-600 text-black border-red-600" : "bg-red-600 text-white border-red-600",
    tabInactive: isDark ? "border-red-600/50 text-red-400/70 hover:bg-neutral-950" : "border-red-600/40 text-red-600/70 hover:bg-red-50",
    overlayBg: isDark ? "bg-red-950/90" : "bg-white/95"
  };

  return (
    <div className={`min-h-screen font-sans selection:bg-red-600 selection:text-white relative overflow-x-hidden pb-16 transition-colors duration-500 ${themeClasses.bg}`}>
      {/* Interactive invisible top bar toggle code revelation */}
      <div 
        className="h-1.5 bg-red-600 cursor-pointer transition-all duration-700 hover:h-6 flex items-center justify-center text-[10px] tracking-[0.4em] text-white overflow-hidden select-none font-mono"
        onClick={() => setTitleVisible(!titleVisible)}
        title="Reveal codename"
      >
        SILENT FIELDS // SPECIAL SIGMATEAM EDITION
      </div>

      <div className="max-w-6xl mx-auto px-4 py-8">
        
        {/* ================= HEADER ================= */}
        <header className={`flex flex-col md:flex-row justify-between items-center gap-6 mb-10 border-b-2 ${themeClasses.border} pb-6`}>
          <div className="flex items-center gap-3">
            <div className={`w-11 h-11 border-2 ${themeClasses.border} flex items-center justify-center font-mono font-bold text-xl hover:bg-red-600 hover:text-white transition-colors duration-300`}>
              Σ
            </div>
            <div>
              <div className="flex items-center gap-2">
                <span className="font-mono text-base tracking-widest uppercase font-bold">SILENT FIELDS</span>
                <span className={`text-[9px] border ${themeClasses.border} px-1.5 py-0.5 font-mono uppercase tracking-wider`}>
                  V1.4
                </span>
              </div>
              <p className="text-[11px] uppercase tracking-wider opacity-85 mt-0.5 font-mono">
                Red & White wallpaper exhibition
              </p>
            </div>
          </div>

          <div className="flex flex-wrap items-center gap-3">
            {/* Dark & Day Toggle Button */}
            <button 
              onClick={() => setIsDark(!isDark)}
              className={`p-2 border-2 ${themeClasses.border} transition-all duration-300 flex items-center gap-2 text-xs font-mono`}
              title={isDark ? "Switch to Day Mode" : "Switch to Dark Mode"}
            >
              {isDark ? (
                <>
                  <Sun className="w-4 h-4 text-red-500 shrink-0" />
                  <span>DAY ON</span>
                </>
              ) : (
                <>
                  <Moon className="w-4 h-4 text-red-600 shrink-0" />
                  <span>DARK ON</span>
                </>
              )}
            </button>

            {/* View Tab Toggle */}
            <div className="flex border-2 border-red-600">
              <button
                onClick={() => setActiveTab("gallery")}
                className={`px-4 py-1.5 text-xs font-mono tracking-widest uppercase transition-all duration-300 flex items-center gap-1.5 ${
                  activeTab === "gallery" ? themeClasses.tabActive : themeClasses.tabInactive
                }`}
              >
                <Grid className="w-3.5 h-3.5" />
                EXHIBIT
              </button>
              <button
                onClick={() => setActiveTab("admin")}
                className={`px-4 py-1.5 text-xs font-mono tracking-widest uppercase transition-all duration-300 flex items-center gap-1.5 ${
                  activeTab === "admin" ? themeClasses.tabActive : themeClasses.tabInactive
                }`}
              >
                <Lock className="w-3.5 h-3.5" />
                PANEL
              </button>
            </div>

            {isLoggedIn && activeTab === "admin" && (
              <button 
                onClick={handleLogout}
                className="flex items-center gap-1.5 text-xs font-mono border-2 border-red-600 bg-red-600 text-white px-3 py-1.5 hover:bg-transparent hover:text-red-600 transition-all uppercase tracking-wider"
              >
                <LogOut className="w-3.5 h-3.5" />
                EXIT
              </button>
            )}
          </div>
        </header>

        {/* ================= CODENAME REVEAL CONTAINER ================= */}
        <AnimatePresence>
          {titleVisible && (
            <motion.div 
              initial={{ opacity: 0, height: 0 }}
              animate={{ opacity: 1, height: "auto" }}
              exit={{ opacity: 0, height: 0 }}
              className={`mb-10 text-center py-8 border-2 ${themeClasses.borderDashed} ${themeClasses.cardBg}`}
            >
              <motion.h2 
                initial={{ letterSpacing: "0.1em" }}
                animate={{ letterSpacing: "0.5em" }}
                className="text-4xl md:text-5xl font-mono font-bold uppercase tracking-widest"
              >
                SILENT FIELDS
              </motion.h2>
              <p className="text-[11px] tracking-widest uppercase font-mono mt-3 opacity-90">
                A RED-SCALE RETROSPECTIVE SPECIFICATION // SIGMATEAM CREATIVE LABS
              </p>
            </motion.div>
          )}
        </AnimatePresence>

        {/* ================= MAIN SWITCHABLE CONTENT ================= */}
        <AnimatePresence mode="wait">
          
          {/* ================= VIEW 1: PUBLIC GALLERY (EXHIBIT) ================= */}
          {activeTab === "gallery" && (
            <motion.div
              key="gallery-view"
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -10 }}
              transition={{ duration: 0.3 }}
              className="space-y-8"
            >
              {/* Category selector & Search bar combined */}
              <div className={`p-6 border-2 ${themeClasses.border} ${themeClasses.cardBg} flex flex-col md:flex-row md:items-center justify-between gap-6`}>
                <div className="space-y-2">
                  <h2 className="font-mono text-sm tracking-widest uppercase font-bold flex items-center gap-2">
                    <Flame className="w-4 h-4 text-red-600" />
                    FILTER SPECIFICATIONS
                  </h2>
                  <div className="flex flex-wrap gap-2">
                    {categories.map((cat) => (
                      <button 
                        key={cat}
                        onClick={() => setCategoryFilter(cat)}
                        className={`px-3 py-1 text-xs font-mono tracking-wider transition-all uppercase ${
                          categoryFilter === cat 
                            ? "bg-red-600 text-white border-2 border-red-600" 
                            : `border-2 ${themeClasses.border} ${themeClasses.text} hover:bg-red-600 hover:text-white`
                        }`}
                      >
                        {cat}
                      </button>
                    ))}
                  </div>
                </div>

                <div className="w-full md:max-w-xs space-y-1.5">
                  <span className="block font-mono text-[10px] tracking-widest uppercase opacity-85">
                    SEARCH REPOSITORY
                  </span>
                  <div className="relative">
                    <Search className="absolute left-3 top-2.5 w-4 h-4 opacity-70" />
                    <input 
                      type="text" 
                      value={searchQuery}
                      onChange={(e) => setSearchQuery(e.target.value)}
                      placeholder="ENTER TAG OR NAME..."
                      className={`w-full border-2 pl-9 pr-4 py-2 text-xs font-mono uppercase tracking-widest transition-all ${themeClasses.input}`}
                    />
                  </div>
                </div>
              </div>

              {/* Gallery List */}
              {filteredWallpapers.length === 0 ? (
                <div className={`border-2 border-dashed ${themeClasses.border} p-16 text-center ${themeClasses.cardBg}`}>
                  <ImageIcon className="w-12 h-12 mx-auto mb-4 opacity-50" />
                  <p className="font-mono text-xs uppercase tracking-widest font-semibold">
                    NO ARTWORK MATCHES THE SELECTED PROFILE.
                  </p>
                </div>
              ) : (
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                  {filteredWallpapers.map((wallpaper, idx) => (
                    <motion.div 
                      key={wallpaper.id}
                      initial={{ opacity: 0, y: 15 }}
                      animate={{ opacity: 1, y: 0 }}
                      transition={{ delay: idx * 0.05 }}
                      className={`border-2 ${themeClasses.border} group overflow-hidden ${themeClasses.cardBg} flex flex-col justify-between hover:scale-[1.01] transition-all`}
                    >
                      {/* Image Frame */}
                      <div className="aspect-[16/9] w-full overflow-hidden bg-neutral-900 relative border-b-2 border-red-600">
                        <img 
                          src={wallpaper.url} 
                          alt={wallpaper.title}
                          className="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                          referrerPolicy="no-referrer"
                        />
                        
                        {/* Interactive Mode Badge */}
                        <div className="absolute top-3 left-3 bg-red-600 text-white font-mono text-[9px] px-2 py-0.5 tracking-widest uppercase">
                          {wallpaper.category}
                        </div>

                        {/* Image Action Overlay */}
                        <div className="absolute inset-0 bg-red-950/80 transition-opacity duration-300 flex items-center justify-center opacity-0 group-hover:opacity-100 gap-4">
                          <button 
                            onClick={() => setSelectedWallpaper(wallpaper)}
                            className="bg-white text-red-600 p-3 hover:bg-red-600 hover:text-white hover:border-white border border-red-600 transition-all"
                            title="Maximize Artwork"
                          >
                            <Maximize2 className="w-4.5 h-4.5" />
                          </button>
                          <button 
                            onClick={() => {
                              const link = document.createElement('a');
                              link.href = wallpaper.url;
                              link.download = `${wallpaper.title.toLowerCase().replace(/\s+/g, '_')}.jpg`;
                              link.click();
                            }}
                            className="bg-white text-red-600 p-3 hover:bg-red-600 hover:text-white hover:border-white border border-red-600 transition-all"
                            title="Download Wallpaper"
                          >
                            <Download className="w-4.5 h-4.5" />
                          </button>
                        </div>
                      </div>

                      {/* Info Panel */}
                      <div className="p-5 flex-grow flex flex-col justify-between gap-4">
                        <div>
                          <div className="flex items-center gap-2">
                            <span className="font-mono text-[10px] tracking-widest opacity-80 uppercase block">
                              {wallpaper.resolution}
                            </span>
                            <span className="opacity-40 font-mono text-[9px]">//</span>
                            <span className="font-mono text-[10px] tracking-widest opacity-80 block">
                              {wallpaper.uploadedAt}
                            </span>
                          </div>
                          <h4 className="font-mono text-base font-bold uppercase tracking-wider mt-2.5">
                            {wallpaper.title}
                          </h4>
                        </div>

                        <div className="pt-3.5 border-t border-dashed border-red-600/30 flex items-center justify-between">
                          <button 
                            onClick={() => setSelectedWallpaper(wallpaper)}
                            className="text-xs font-mono font-bold tracking-widest uppercase hover:underline flex items-center gap-1"
                          >
                            <Eye className="w-3.5 h-3.5" />
                            VIEW SCREEN
                          </button>
                          <button 
                            onClick={() => {
                              const link = document.createElement('a');
                              link.href = wallpaper.url;
                              link.download = `${wallpaper.title.toLowerCase().replace(/\s+/g, '_')}.jpg`;
                              link.click();
                            }}
                            className={`px-3 py-1 text-[11px] font-mono tracking-widest uppercase border border-red-600 hover:bg-red-600 hover:text-white transition-all`}
                          >
                            GET FILE
                          </button>
                        </div>
                      </div>
                    </motion.div>
                  ))}
                </div>
              )}
            </motion.div>
          )}

          {/* ================= VIEW 2: ADMIN PORTAL ================= */}
          {activeTab === "admin" && (
            <motion.div
              key="admin-view"
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -10 }}
              transition={{ duration: 0.3 }}
            >
              {!isLoggedIn ? (
                /* ================= ADMIN LOGIN ================= */
                <div className={`max-w-md mx-auto my-8 border-2 ${themeClasses.border} p-8 ${themeClasses.cardBg} relative`}>
                  {/* Decorative corner framing */}
                  <div className="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-red-600" />
                  <div className="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-red-600" />
                  <div className="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-red-600" />
                  <div className="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-red-600" />

                  <div className="text-center mb-8">
                    <Lock className="w-8 h-8 mx-auto mb-3" />
                    <h3 className="font-mono text-base tracking-widest uppercase font-bold">SIGMATEAM TERMINAL ACCESS</h3>
                    <p className="text-[10px] uppercase tracking-wider opacity-80 mt-1 font-mono">
                      SECURE WALLPAPER CONTROL CONSOLE
                    </p>
                  </div>

                  <form onSubmit={handleLogin} className="space-y-6">
                    <div>
                      <label className="block font-mono text-xs uppercase tracking-widest mb-1.5 font-bold">
                        Username
                      </label>
                      <input 
                        type="text" 
                        value={username}
                        onChange={(e) => setUsername(e.target.value)}
                        required
                        placeholder="ENTER USERNAME"
                        className={`w-full border-2 p-3 font-mono text-sm transition-all uppercase tracking-wider ${themeClasses.input}`}
                      />
                    </div>

                    <div>
                      <label className="block font-mono text-xs uppercase tracking-widest mb-1.5 font-bold">
                        Password
                      </label>
                      <input 
                        type="password" 
                        value={password}
                        onChange={(e) => setPassword(e.target.value)}
                        required
                        placeholder="ENTER PASSWORD"
                        className={`w-full border-2 p-3 font-mono text-sm transition-all ${themeClasses.input}`}
                      />
                    </div>

                    {loginError && (
                      <div className="flex items-center gap-2 border-2 border-red-600 p-3.5 text-xs bg-red-950/20 font-mono text-red-500">
                        <AlertCircle className="w-4 h-4 shrink-0" />
                        <span>{loginError}</span>
                      </div>
                    )}

                    <button 
                      type="submit"
                      className={`w-full py-3 border-2 font-mono font-bold tracking-widest uppercase transition-all duration-300 ${themeClasses.buttonSolid}`}
                    >
                      SECURE SIGN IN
                    </button>
                  </form>
                  
                  <div className="mt-8 pt-4 border-t border-dashed border-red-600/40 text-center">
                    <span className="text-[9px] font-mono tracking-widest opacity-75">
                      AUTHORIZED PERSONNEL USE ONLY
                    </span>
                  </div>
                </div>
              ) : (
                /* ================= LOGGED IN CONTROL PANEL ================= */
                <div className="space-y-10">
                  <div className="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    
                    {/* File Upload Control Frame */}
                    <div className={`lg:col-span-2 border-2 ${themeClasses.border} p-6 relative ${themeClasses.cardBg}`}>
                      <h3 className="font-mono text-sm tracking-widest uppercase font-bold mb-6 flex items-center gap-2 border-b border-red-600 pb-2">
                        <Upload className="w-4 h-4 text-red-600" />
                        ADD COMPOSITION
                      </h3>

                      <form onSubmit={handleUploadSubmit} className="space-y-6">
                        {/* Drag & Drop Frame */}
                        <div 
                          onDragEnter={handleDrag}
                          onDragOver={handleDrag}
                          onDragLeave={handleDrag}
                          onDrop={handleDrop}
                          onClick={() => fileInputRef.current?.click()}
                          className={`border-2 border-dashed p-6 text-center cursor-pointer transition-all flex flex-col items-center justify-center min-h-[170px] relative ${
                            dragActive 
                              ? "border-red-600 bg-red-600/10 scale-[0.99]" 
                              : `border-red-600/50 hover:border-red-600 hover:bg-red-600/5`
                          }`}
                        >
                          <input 
                            ref={fileInputRef}
                            type="file" 
                            accept="image/*"
                            onChange={handleFileChange}
                            className="hidden"
                          />

                          {uploadPreview ? (
                            <div className="w-full flex flex-col items-center gap-3">
                              <img 
                                src={uploadPreview} 
                                alt="Preview" 
                                className="max-h-24 object-contain border-2 border-red-600"
                                referrerPolicy="no-referrer"
                              />
                              <p className="text-xs font-mono truncate max-w-xs">{uploadFile?.name}</p>
                              <button 
                                type="button"
                                onClick={(e) => {
                                  e.stopPropagation();
                                  setUploadFile(null);
                                  setUploadPreview(null);
                                }}
                                className="text-[9px] font-mono border border-red-600 px-2 py-0.5 hover:bg-red-600 hover:text-white"
                              >
                                FLUSH IMAGE
                              </button>
                            </div>
                          ) : (
                            <div className="space-y-2">
                              <FileImage className="w-10 h-10 mx-auto opacity-70" />
                              <p className="font-mono text-xs uppercase tracking-wider font-semibold">
                                Drag & Drop Image Here or Browse
                              </p>
                              <p className="text-[10px] font-mono opacity-70">
                                Support Red/White theme JPG, PNG, WEBP formats
                              </p>
                            </div>
                          )}
                        </div>

                        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                          <div>
                            <label className="block font-mono text-xs uppercase tracking-widest mb-1.5 font-bold">
                              Wallpaper Title
                            </label>
                            <input 
                              type="text" 
                              value={uploadTitle}
                              onChange={(e) => setUploadTitle(e.target.value)}
                              required
                              placeholder="E.G. SCARLET REEDS"
                              className={`w-full border-2 p-2.5 font-mono text-xs transition-all uppercase ${themeClasses.input}`}
                            />
                          </div>

                          <div>
                            <label className="block font-mono text-xs uppercase tracking-widest mb-1.5 font-bold">
                              Composition Category
                            </label>
                            <select 
                              value={uploadCategory}
                              onChange={(e) => setUploadCategory(e.target.value)}
                              className={`w-full border-2 p-2.5 font-mono text-xs transition-all ${themeClasses.input}`}
                            >
                              <option value="Minimalist">Minimalist</option>
                              <option value="Nature">Nature</option>
                              <option value="Abstract">Abstract</option>
                              <option value="Custom">Custom</option>
                            </select>
                          </div>
                        </div>

                        {uploadError && (
                          <div className="flex items-center gap-2 border border-red-600 p-3 text-xs bg-red-950/10 font-mono">
                            <AlertCircle className="w-4 h-4 shrink-0" />
                            <span>{uploadError}</span>
                          </div>
                        )}

                        {uploadSuccess && (
                          <div className="flex items-center gap-2 border border-red-600 p-3.5 text-xs bg-red-950/10 font-mono">
                            <CheckCircle className="w-4 h-4 shrink-0 text-red-600" />
                            <span>COMPOSITION REGISTERED SUCCESSFULLY IN SYSTEM STORAGE!</span>
                          </div>
                        )}

                        <button 
                          type="submit"
                          className={`w-full py-3 font-mono font-bold tracking-widest uppercase transition-all duration-300 flex items-center justify-center gap-2 border-2 ${themeClasses.buttonSolid}`}
                        >
                          <Plus className="w-4 h-4" />
                          PUBLISH COMPOSITION
                        </button>
                      </form>
                    </div>

                    {/* Quick Control Console Panel */}
                    <div className={`border-2 ${themeClasses.border} p-6 flex flex-col justify-between relative ${themeClasses.cardBg}`}>
                      <div>
                        <h3 className="font-mono text-sm tracking-widest uppercase font-bold mb-6 flex items-center gap-2 border-b border-red-600 pb-2">
                          <Sparkles className="w-4 h-4" />
                          OPERATIONS STATUS
                        </h3>

                        <div className="space-y-4">
                          <div className="border border-red-600/60 p-4">
                            <span className="font-mono text-[10px] uppercase tracking-widest block opacity-75">
                              TOTAL EXHIBITS
                            </span>
                            <span className="text-3xl font-mono font-bold block mt-1">{wallpapers.length}</span>
                          </div>

                          <div className="border border-red-600/60 p-4">
                            <span className="font-mono text-[10px] uppercase tracking-widest block opacity-75">
                              SYSTEM PROFILE
                            </span>
                            <span className="text-xs font-mono font-bold uppercase block mt-1">
                              {isDark ? "DARKROOM CONTRAST" : "LIGHT FIELDS CONTRAST"}
                            </span>
                          </div>

                          <div className="border border-red-600/60 p-4">
                            <span className="font-mono text-[10px] uppercase tracking-widest block opacity-75">
                              GATEWAY CREDENTIALS
                            </span>
                            <span className="text-xs font-mono font-semibold block mt-1 flex items-center gap-1">
                              <ShieldCheck className="w-4 h-4 text-red-600" />
                              SIGMATEAM OPERATOR
                            </span>
                          </div>
                        </div>
                      </div>

                      <div className="pt-6 border-t border-dashed border-red-600/40 text-center">
                        <p className="text-[10px] font-mono tracking-widest opacity-70 uppercase">
                          SECURE CONSOLE // ONLINE
                        </p>
                      </div>
                    </div>

                  </div>

                  {/* Active Admin Repository Manager list */}
                  <div className="space-y-6">
                    <h3 className="font-mono text-sm tracking-widest uppercase font-bold border-b-2 border-red-600 pb-2 flex items-center gap-2">
                      <Trash2 className="w-4 h-4" />
                      FLUSH OR DELETE ARCHIVES
                    </h3>

                    <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                      {wallpapers.map((wallpaper) => (
                        <div 
                          key={wallpaper.id} 
                          className={`border-2 ${themeClasses.border} ${themeClasses.cardBg} overflow-hidden flex flex-col justify-between`}
                        >
                          <div className="aspect-video relative border-b border-red-600/40 bg-zinc-900">
                            <img 
                              src={wallpaper.url} 
                              alt={wallpaper.title} 
                              className="w-full h-full object-cover"
                              referrerPolicy="no-referrer"
                            />
                            <div className="absolute top-2 right-2 bg-red-600 text-white text-[9px] font-mono px-1.5 py-0.5 uppercase">
                              {wallpaper.category}
                            </div>
                          </div>

                          <div className="p-4 flex-grow flex flex-col justify-between gap-3">
                            <div>
                              <h4 className="font-mono text-xs font-bold uppercase truncate">
                                {wallpaper.title}
                              </h4>
                              <p className="text-[10px] font-mono opacity-80 mt-1">
                                {wallpaper.resolution}
                              </p>
                            </div>

                            <button
                              onClick={() => setDeleteConfirmId(wallpaper.id)}
                              className="w-full py-1.5 text-[11px] font-mono tracking-widest uppercase text-red-600 hover:bg-red-600 hover:text-white border border-red-600 transition-colors flex items-center justify-center gap-1"
                            >
                              <Trash2 className="w-3.5 h-3.5" />
                              DELETE FILE
                            </button>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              )}
            </motion.div>
          )}

        </AnimatePresence>
      </div>

      {/* ================= LIGHTBOX PREVIEW MODAL ================= */}
      <AnimatePresence>
        {selectedWallpaper && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 bg-neutral-950/95 backdrop-blur-sm z-50 flex items-center justify-center p-4"
          >
            <motion.div 
              initial={{ scale: 0.96 }}
              animate={{ scale: 1 }}
              exit={{ scale: 0.96 }}
              className={`border-2 border-red-600 max-w-4xl w-full ${themeClasses.cardBg}`}
            >
              <div className="p-4 border-b-2 border-red-600 flex justify-between items-center text-red-600 bg-black/5">
                <span className="font-mono text-xs uppercase tracking-widest font-bold">
                  ARTWORK PREVIEW // {selectedWallpaper.title}
                </span>
                <button 
                  onClick={() => setSelectedWallpaper(null)}
                  className="hover:bg-red-600 hover:text-white p-1.5 border border-red-600 transition-colors"
                >
                  <X className="w-4 h-4" />
                </button>
              </div>

              <div className="p-4 bg-zinc-950 flex items-center justify-center border-b-2 border-red-600">
                <img 
                  src={selectedWallpaper.url} 
                  alt={selectedWallpaper.title} 
                  className="max-h-[55vh] object-contain border border-red-600/40"
                  referrerPolicy="no-referrer"
                />
              </div>

              <div className="p-5 grid grid-cols-1 sm:grid-cols-3 gap-4 font-mono text-[11px]">
                <div className="border-r border-red-600/20 pr-4">
                  <span className="block opacity-75 uppercase tracking-widest mb-1 text-[9px]">COMPOSITION ID</span>
                  <span className="font-bold block uppercase">{selectedWallpaper.id}</span>
                </div>
                <div className="border-r border-red-600/20 pr-4">
                  <span className="block opacity-75 uppercase tracking-widest mb-1 text-[9px]">MAX RESOLUTION</span>
                  <span className="font-bold block">3840 x 2160 (4K UHD)</span>
                </div>
                <div>
                  <span className="block opacity-75 uppercase tracking-widest mb-1 text-[9px]">ARCHIVE DATE</span>
                  <span className="font-bold block">{selectedWallpaper.uploadedAt}</span>
                </div>
              </div>

              <div className="p-4 border-t border-red-600 bg-red-600/5 flex justify-end gap-3">
                <button 
                  onClick={() => {
                    const link = document.createElement('a');
                    link.href = selectedWallpaper.url;
                    link.download = `${selectedWallpaper.title.toLowerCase().replace(/\s+/g, '_')}.jpg`;
                    link.click();
                  }}
                  className="px-4 py-2 bg-red-600 text-white hover:bg-transparent hover:text-red-600 border border-red-600 transition-all font-mono text-xs font-bold tracking-widest uppercase flex items-center gap-2"
                >
                  <Download className="w-4 h-4" />
                  DOWNLOAD FILE
                </button>
                <button 
                  onClick={() => setSelectedWallpaper(null)}
                  className="px-4 py-2 border border-red-600 text-red-600 hover:bg-red-600 hover:text-white transition-all font-mono text-xs font-bold tracking-widest uppercase"
                >
                  DISMISS
                </button>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>

      {/* ================= DELETE CONFIRMATION DIALOG ================= */}
      <AnimatePresence>
        {deleteConfirmId && (
          <motion.div 
            initial={{ opacity: 0 }}
            animate={{ opacity: 1 }}
            exit={{ opacity: 0 }}
            className="fixed inset-0 bg-neutral-950/90 backdrop-blur-sm z-50 flex items-center justify-center p-4"
          >
            <motion.div 
              initial={{ scale: 0.95 }}
              animate={{ scale: 1 }}
              exit={{ scale: 0.95 }}
              className="bg-zinc-950 border-4 border-red-600 max-w-md w-full p-6 text-center text-red-500"
            >
              <Trash2 className="w-12 h-12 text-red-600 mx-auto mb-4" />
              <h3 className="font-mono text-base font-bold uppercase tracking-widest mb-2 text-white">
                CONFIRM ACTION
              </h3>
              <p className="font-mono text-[11px] opacity-90 mb-6 uppercase tracking-wider leading-relaxed">
                ARE YOU ABSOLUTELY SURE YOU WANT TO DESTRUCTIVELY PURGE THIS COMPOSITION FROM THE SYSTEM REPOSITORY? THIS CANNOT BE RECOVERED.
              </p>

              <div className="flex gap-4">
                <button 
                  onClick={() => handleDeleteWallpaper(deleteConfirmId)}
                  className="flex-1 py-2.5 bg-red-600 text-black hover:bg-black hover:text-red-500 border-2 border-red-600 font-mono font-bold tracking-widest uppercase transition-all"
                >
                  CONFIRM PURGE
                </button>
                <button 
                  onClick={() => setDeleteConfirmId(null)}
                  className="flex-1 py-2.5 border-2 border-red-600 text-red-500 hover:bg-neutral-900 font-mono font-bold tracking-widest uppercase transition-all"
                >
                  ABORT
                </button>
              </div>
            </motion.div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}
